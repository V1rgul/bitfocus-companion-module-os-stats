{
	"name": "os-stats",
	"version": "0.1.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"dev": "yarn build:main --watch",
		"build": "rimraf dist && tsc -p tsconfig.build.json",
		"build:main": "tsc -p tsconfig.build.json",
		"lint:raw": "./node_modules/.bin/eslint --ext .ts --ext .js --ignore-pattern dist --ignore-pattern pkg",
		"lint": "yarn lint:raw src eslint.config.mjs",
		"dist": "yarn companion-module-build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/V1rgul/bitfocus-companion-module-os-stats.git"
	},
	"engines": {
		"node": "^22.20"
	},
	"dependencies": {
		"@companion-module/base": "~2.0.4"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.1",
		"@types/node": "^22.19.17",
		"eslint": "^9.39.4",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.58.2"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"packageManager": "yarn@4.13.0"
}
